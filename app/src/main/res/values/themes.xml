<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main app theme -->
    <style name="Theme.ConnectSplashApp" parent="android:Theme.Material.Light.NoActionBar" />
    
    <!-- Splash screen theme -->
    <style name="Theme.ConnectSplashApp.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/connect_logo</item>
        <item name="windowSplashScreenAnimationDuration">1500</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.ConnectSplashApp</item>
    </style>
</resources>